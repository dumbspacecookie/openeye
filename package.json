{
  "name": "@dumbspacecookie/openeye",
  "version": "0.1.0",
  "description": "Persistent memory, visual session tracking, and RL trajectory capture for AR/XR — the shared brain for every headset",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./memory": {
      "import": "./dist/memory.js",
      "types": "./dist/memory.d.ts"
    },
    "./models": {
      "import": "./dist/models.js",
      "types": "./dist/models.d.ts"
    },
    "./tools": {
      "import": "./dist/tools.js",
      "types": "./dist/tools.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run typecheck && npm run build && rimraf sidecar/__pycache__ tests/__pycache__",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "~0.66.0",
    "@mariozechner/pi-ai": "~0.66.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "sidecar/",
    "skills/",
    "schemas/"
  ],
  "keywords": [
    "openeye", "ai-agent", "ar", "xr", "computer-vision",
    "procedure-verification", "rl-training", "dpo", "pi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dumbspacecookie/openeye"
  }
}
