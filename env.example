# ── Required (pick one) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...

# ── OpenEye config ───────────────────────────────────────────────────────────
# OPENEYE_HOME=~/.openeye           # data directory (SQLite DB + skills)
# OPENEYE_PORT=7770                 # sidecar HTTP port
# OPENEYE_PYTHON=python3            # Python executable

# ── Cloud sync (opt-in) ──────────────────────────────────────────────────────
# OPENEYE_CLOUD_URL=                # cloud endpoint
# OPENEYE_CLOUD_KEY=                # API key for cloud sync
# OPENEYE_SYNC_INTERVAL=60          # sync interval in seconds

# ── Vision ───────────────────────────────────────────────────────────────────
# OPENEYE_VISION_MODEL=             # vision model for image-native logFrame

# ── Local models ─────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── HuggingFace ──────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...

# ── OpenRouter ───────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-v1-...

# ── AWS Bedrock ──────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
